  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.ts,.vue --max-warnings 0",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,html}\"",
