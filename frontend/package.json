    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.23.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.5",
    "typescript": "^5.2.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.9",
