<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Logback configuration for unit tests to keep the output clean -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- Suppress expected error logs from GlobalExceptionHandler during unit tests -->
    <logger name="de.maintenancetool.error.GlobalExceptionHandler" level="OFF" />
</configuration>
