<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ChangeSet 1: Erstellen des initialen Datenbankschemas für die Basisinfrastruktur -->
    <changeSet id="001-initial-schema" author="simon">
        
        <!-- 1. Tabelle: user_account -->
        <createTable tableName="user_account">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_user_account"/>
            </column>
            <column name="mail_adresse" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uc_user_account_mail"/>
            </column>
            <column name="voller_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="login_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- 2. Tabelle: user_account_rollen (ElementCollection für Rollen) -->
        <createTable tableName="user_account_rollen">
            <column name="user_account_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="rolle" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="user_account_rollen" baseColumnNames="user_account_id"
                                 referencedTableName="user_account" referencedColumnNames="id"
                                 constraintName="fk_user_rollen_to_user" onDelete="CASCADE"/>

        <!-- 3. Tabelle: stored_file (Dateimetadaten) -->
        <createTable tableName="stored_file">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_stored_file"/>
            </column>
            <column name="original_dateiname" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="dateipfad" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="content_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="dateigroesse" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="upload_datum" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

    </changeSet>
</databaseChangeLog>
